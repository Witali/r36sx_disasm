diff --git a/src/compat/sound.c b/src/compat/sound.c
--- a/src/compat/sound.c
+++ b/src/compat/sound.c
@@
 void sound_lowlevel_frame(libspectrum_signed_word *data, int len)
 {
-   audio_cb( data, (size_t)len / 2 );
+   size_t frames = (size_t)len / 2;
+
+   if (audio_cb)
+   {
+      audio_cb( data, frames );
+   }
+   else if (audio_sample_cb)
+   {
+      size_t i;
+
+      for (i = 0; i < frames; i++)
+      {
+         audio_sample_cb( data[i * 2], data[i * 2 + 1] );
+      }
+   }
+
    some_audio = 1;
 }
